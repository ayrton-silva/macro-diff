datasource db {
    provider = "postgresql"
}

generator client {
    provider = "prisma-client"
    output   = "./generated/prisma"
}

model Summoner {
    id              String           @id
    gameName        String
    tagLine         String
    summonerLeagues SummonerLeague[]
    level           Int
    revisionDate    String
    profileIconId   Int
    participants    Participant[]
}

model SummonerLeague {
    id           String   @id
    queueType    String
    tier         String
    rank         String
    summoner     Summoner @relation(fields: [summonerId], references: [id])
    summonerId   String
    leaguePoints Int
    wins         Int
    losses       Int
    veteran      Boolean
    inactive     Boolean
    freshBlood   Boolean
    hotStreak    Boolean
}

model Match {
    matchId      String        @id
    gameDuration Int
    gameEndTimestamp String
    gameMode     String
    gameType     String
    participants Participant[]
}

model Participant {
    summonerId                  String
    matchId                     String
    summoner                    Summoner @relation(fields: [summonerId], references: [id])
    match                       Match    @relation(fields: [matchId], references: [matchId])
    championName                String
    lane                        String
    teamPosition                String
    summoner1Id                 Int
    summoner2Id                 Int
    totalMinionsKilled          Int
    totalDamageDealtToChampions Int
    wardsPlaced                 Int
    goldEarned                  Int
    item0                       Int
    item1                       Int
    item2                       Int
    item3                       Int
    item4                       Int
    item5                       Int
    item6                       Int
    teamId                      String
    win                         Boolean

    @@id(name: "participantId", [summonerId, matchId])
}
