datasource db {
    provider = "postgresql"
}

generator client {
    provider = "prisma-client"
    output   = "./generated/prisma"
}

model Summoner {
    id              String           @id
    gameName        String
    tagLine         String
    summonerLeagues SummonerLeague[]
    level           Int
    revisionDate    BigInt
    profileIconId   Int
}

model SummonerLeague {
    id           String   @id
    queueType    String
    tier         String
    rank         String
    summoner     Summoner @relation(fields: [summonerId], references: [id])
    summonerId   String
    leaguePoints Int
    wins         Int
    losses       Int
    veteran      Boolean
    inactive     Boolean
    freshBlood   Boolean
    hotStreak    Boolean
}
